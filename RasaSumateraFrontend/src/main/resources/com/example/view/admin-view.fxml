<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<HBox maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="650.0" prefWidth="950.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.controller.AdminController">
    <children>
        <VBox prefWidth="220.0" spacing="10.0" style="-fx-background-color: #791F1F;">
            <children>
                <VBox prefHeight="80.0" spacing="2.0">
                    <children>
                        <Label text="RasaSumatera" textFill="WHITE">
                            <font>
                                <Font name="System Bold" size="18.0" />
                            </font>
                        </Label>
                        <Label text="Admin Dashboard" textFill="#ffb3b3">
                            <font>
                                <Font size="12.0" />
                            </font>
                        </Label>
                    </children>
                    <padding>
                        <Insets bottom="15.0" left="20.0" right="20.0" top="20.0" />
                    </padding>
                </VBox>
                <Button alignment="BASELINE_LEFT" maxWidth="1.7976931348623157E308" mnemonicParsing="false" prefHeight="45.0" style="-fx-background-color: #A32D2D; -fx-cursor: hand;" text=" 🍴  Kelola Kuliner" textFill="WHITE" />
                <Button alignment="BASELINE_LEFT" maxWidth="1.7976931348623157E308" mnemonicParsing="false" prefHeight="45.0" style="-fx-background-color: transparent; -fx-cursor: hand;" text=" 💬  Ulasan Pengguna" textFill="#ffcccc" />
                <Button alignment="BASELINE_LEFT" maxWidth="1.7976931348623157E308" mnemonicParsing="false" prefHeight="45.0" style="-fx-background-color: transparent; -fx-cursor: hand;" text=" 📊  Statistik" textFill="#ffcccc" />
                <VBox alignment="BOTTOM_CENTER" VBox.vgrow="ALWAYS">
                    <children>
                        <Button alignment="CENTER" maxWidth="1.7976931348623157E308" mnemonicParsing="false" prefHeight="40.0" style="-fx-background-color: #5a1717; -fx-background-radius: 5;" text="Keluar" textFill="WHITE">
                            <VBox.margin>
                                <Insets bottom="20.0" left="20.0" right="20.0" />
                            </VBox.margin>
                        </Button>
                    </children>
                </VBox>
            </children>
        </VBox>

        <VBox spacing="20.0" HBox.hgrow="ALWAYS" style="-fx-background-color: #FDFDFD;">
            <padding>
                <Insets bottom="25.0" left="25.0" right="25.0" top="25.0" />
            </padding>
            <children>
                <Label text="Kelola Data Kuliner" textFill="#791F1F">
                    <font>
                        <Font name="System Bold" size="24.0" />
                    </font>
                </Label>

                <HBox spacing="20.0">
                    <children>
                        <VBox prefHeight="70.0" prefWidth="180.0" style="-fx-background-color: #FFF; -fx-border-color: #EEE; -fx-border-radius: 10; -fx-background-radius: 10; -fx-padding: 10;">
                            <children>
                                <Label text="124" textFill="#A32D2D">
                                    <font>
                                        <Font name="System Bold" size="22.0" />
                                    </font>
                                </Label>
                                <Label text="Total Kuliner" textFill="#777777" />
                            </children>
                        </VBox>
                        <VBox prefHeight="70.0" prefWidth="180.0" style="-fx-background-color: #FFF; -fx-border-color: #EEE; -fx-border-radius: 10; -fx-background-radius: 10; -fx-padding: 10;">
                            <children>
                                <Label text="8" textFill="#A32D2D">
                                    <font>
                                        <Font name="System Bold" size="22.0" />
                                    </font>
                                </Label>
                                <Label text="Provinsi" textFill="#777777" />
                            </children>
                        </VBox>
                        <VBox prefHeight="70.0" prefWidth="180.0" style="-fx-background-color: #FFF; -fx-border-color: #EEE; -fx-border-radius: 10; -fx-background-radius: 10; -fx-padding: 10;">
                            <children>
                                <Label text="512" textFill="#A32D2D">
                                    <font>
                                        <Font name="System Bold" size="22.0" />
                                    </font>
                                </Label>
                                <Label text="Ulasan" textFill="#777777" />
                            </children>
                        </VBox>
                    </children>
                </HBox>

                <VBox spacing="10.0" style="-fx-background-color: #FFF; -fx-border-color: #EEE; -fx-border-radius: 10; -fx-background-radius: 10; -fx-padding: 20;">
                    <children>
                        <HBox spacing="15.0">
                            <children>
                                <VBox spacing="8.0" HBox.hgrow="ALWAYS">
                                    <children>
                                        <Label text="Nama Kuliner" textFill="#555555" style="-fx-font-weight: bold;" />
                                        <TextField fx:id="inputNamaKuliner" promptText="Contoh: Bika Ambon" prefHeight="35.0" />
                                    </children>
                                </VBox>
                                <VBox spacing="8.0" HBox.hgrow="ALWAYS">
                                    <children>
                                        <Label text="Asal Daerah" textFill="#555555" style="-fx-font-weight: bold;" />
                                        <ComboBox fx:id="comboDaerah" prefHeight="35.0" prefWidth="1000.0" promptText="-- Pilih Provinsi --" />
                                    </children>
                                </VBox>
                            </children>
                        </HBox>
                        <VBox spacing="8.0">
                            <children>
                                <Label text="Deskripsi" textFill="#555555" style="-fx-font-weight: bold;" />
                                <TextArea fx:id="inputDeskripsi" prefHeight="60.0" promptText="Tuliskan sejarah singkat atau info makanan..." wrapText="true" />
                            </children>
                        </VBox>
                        <HBox alignment="CENTER_RIGHT" spacing="10.0">
                            <children>
                                <Button fx:id="btnSimpan" onAction="#handleSimpan" prefHeight="35.0" prefWidth="120.0" style="-fx-background-color: #A32D2D; -fx-font-weight: bold;" text="Simpan Data" textFill="WHITE" />
                                <Button fx:id="btnHapus" onAction="#handleHapus" prefHeight="35.0" prefWidth="120.0" style="-fx-background-color: #D93838;" text="Hapus Terpilih" textFill="WHITE" />
                            </children>
                        </HBox>
                    </children>
                </VBox>

                <TableView fx:id="tableKuliner" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colNama" prefWidth="180.0" text="Nama Kuliner" />
                        <TableColumn fx:id="colDaerah" prefWidth="150.0" text="Asal Daerah" />
                        <TableColumn fx:id="colDeskripsi" prefWidth="350.0" text="Deskripsi Singkat" />
                    </columns>
                </TableView>
            </children>
        </VBox>
    </children>
</HBox>