<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.shape.Rectangle?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.text.Text?>

<!--
  login.fxml — Kuliner Sumatera
  Controller : com.example.controller.LoginController
  Ukuran     : 580 x 450
-->

<HBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.example.controller.LoginController"
      prefWidth="580.0" prefHeight="450.0"
      style="-fx-background-radius: 16; -fx-background-color: white;">

    <!-- ═══════════════════════════════════════
         PANEL KIRI — Merah + pattern makanan
         ═══════════════════════════════════════ -->
    <VBox prefWidth="220.0" prefHeight="450.0"
          style="-fx-background-color: #C0392B;">

        <!-- Pattern ikon makanan (Grid 3x4) -->
        <GridPane style="-fx-padding: 0;" prefWidth="220.0" prefHeight="370.0"
                  opacity="0.55">
            <!-- Baris 1 -->
            <Label text="🍜" style="-fx-font-size: 42px;"
                   GridPane.columnIndex="0" GridPane.rowIndex="0"
                   prefWidth="73" prefHeight="70" alignment="CENTER"/>
            <Label text="🫕" style="-fx-font-size: 42px;"
                   GridPane.columnIndex="1" GridPane.rowIndex="0"
                   prefWidth="73" prefHeight="70" alignment="CENTER"/>
            <Label text="🍖" style="-fx-font-size: 42px;"
                   GridPane.columnIndex="2" GridPane.rowIndex="0"
                   prefWidth="73" prefHeight="70" alignment="CENTER"/>
            <!-- Baris 2 -->
            <Label text="🌶️" style="-fx-font-size: 42px;"
                   GridPane.columnIndex="0" GridPane.rowIndex="1"
                   prefWidth="73" prefHeight="70" alignment="CENTER"/>
            <Label text="🐟" style="-fx-font-size: 42px;"
                   GridPane.columnIndex="1" GridPane.rowIndex="1"
                   prefWidth="73" prefHeight="70" alignment="CENTER"/>
            <Label text="☕" style="-fx-font-size: 42px;"
                   GridPane.columnIndex="2" GridPane.rowIndex="1"
                   prefWidth="73" prefHeight="70" alignment="CENTER"/>
            <!-- Baris 3 -->
            <Label text="🥮" style="-fx-font-size: 42px;"
                   GridPane.columnIndex="0" GridPane.rowIndex="2"
                   prefWidth="73" prefHeight="70" alignment="CENTER"/>
            <Label text="🍛" style="-fx-font-size: 42px;"
                   GridPane.columnIndex="1" GridPane.rowIndex="2"
                   prefWidth="73" prefHeight="70" alignment="CENTER"/>
            <Label text="🧆" style="-fx-font-size: 42px;"
                   GridPane.columnIndex="2" GridPane.rowIndex="2"
                   prefWidth="73" prefHeight="70" alignment="CENTER"/>
            <!-- Baris 4 -->
            <Label text="🍢" style="-fx-font-size: 42px;"
                   GridPane.columnIndex="0" GridPane.rowIndex="3"
                   prefWidth="73" prefHeight="70" alignment="CENTER"/>
            <Label text="🫙" style="-fx-font-size: 42px;"
                   GridPane.columnIndex="1" GridPane.rowIndex="3"
                   prefWidth="73" prefHeight="70" alignment="CENTER"/>
            <Label text="🥘" style="-fx-font-size: 42px;"
                   GridPane.columnIndex="2" GridPane.rowIndex="3"
                   prefWidth="73" prefHeight="70" alignment="CENTER"/>
        </GridPane>

        <!-- Judul bawah kiri -->
        <VBox VBox.vgrow="ALWAYS" alignment="BOTTOM_LEFT">
            <padding><Insets bottom="24" left="20" right="20" top="0"/></padding>
            <Label text="Kulineranyuk!"
                   textFill="WHITE"
                   style="-fx-font-size: 26px; -fx-font-weight: bold; -fx-font-style: italic;"/>
        </VBox>
    </VBox>

    <!-- ═══════════════════════════════════════
         PANEL KANAN — Form Login
         ═══════════════════════════════════════ -->
    <VBox prefWidth="360.0" prefHeight="450.0"
          alignment="TOP_CENTER"
          style="-fx-background-color: white; -fx-background-radius: 0 16 16 0;">
        <padding><Insets top="32" bottom="28" left="28" right="28"/></padding>

        <!-- Ikon brand -->
        <Label text="🍜"
               alignment="CENTER"
               style="-fx-background-color: #FEE8E6; -fx-background-radius: 12; -fx-font-size: 24px; -fx-pref-width: 44; -fx-pref-height: 44;"
               maxWidth="44"/>

        <VBox.margin><Insets top="10"/></VBox.margin>

        <!-- Judul -->
        <Label text="RasaSumatera"
               textFill="#A32D2D"
               alignment="CENTER"
               maxWidth="Infinity"
               style="-fx-font-size: 17px; -fx-font-weight: bold;"/>

        <!-- Subjudul -->
        <Label text="Selamat datang kembali"
               textFill="#888888"
               alignment="CENTER"
               maxWidth="Infinity"
               style="-fx-font-size: 12px;">
            <VBox.margin><Insets top="2" bottom="14"/></VBox.margin>
        </Label>

        <!-- Tab Masuk / Daftar -->
        <HBox style="-fx-border-color: #E5E5E5; -fx-border-radius: 9; -fx-background-radius: 9;
                     -fx-border-width: 1.5; -fx-padding: 3; -fx-spacing: 0;"
              maxWidth="Infinity">
            <Button text="Masuk" maxWidth="Infinity" HBox.hgrow="ALWAYS"
                    style="-fx-background-color: #C0392B; -fx-text-fill: white;
                           -fx-font-weight: bold; -fx-font-size: 13px;
                           -fx-background-radius: 7; -fx-cursor: hand;"
                    onAction="#goToLogin"/>
            <Button text="Daftar" maxWidth="Infinity" HBox.hgrow="ALWAYS"
                    style="-fx-background-color: transparent; -fx-text-fill: #888;
                           -fx-font-size: 13px; -fx-background-radius: 7; -fx-cursor: hand;"
                    onAction="#goToRegister"/>
            <VBox.margin><Insets bottom="16"/></VBox.margin>
        </HBox>

        <!-- Field Email -->
        <VBox spacing="4.0">
            <Label text="Email"
                   textFill="#555555"
                   style="-fx-font-weight: bold; -fx-font-size: 12px;"/>
            <TextField fx:id="inputEmail"
                       promptText="budi@gmail.com"
                       style="-fx-background-color: #F9F9F9;
                              -fx-border-color: #E6E6E6;
                              -fx-border-radius: 8; -fx-background-radius: 8;
                              -fx-font-size: 13px; -fx-padding: 8 11 8 11;"/>
            <Label fx:id="lblErrorEmail"
                   text="⚠ Format email tidak valid"
                   textFill="#D93838"
                   visible="false" managed="false"
                   style="-fx-font-size: 11px;"/>
            <VBox.margin><Insets bottom="4"/></VBox.margin>
        </VBox>

        <!-- Field Password -->
        <VBox spacing="4.0">
            <Label text="Password"
                   textFill="#555555"
                   style="-fx-font-weight: bold; -fx-font-size: 12px;"/>
            <StackPane>
                <PasswordField fx:id="inputPassword"
                               promptText="••••••••"
                               style="-fx-background-color: #F9F9F9;
                                      -fx-border-color: #E6E6E6;
                                      -fx-border-radius: 8; -fx-background-radius: 8;
                                      -fx-font-size: 13px; -fx-padding: 8 36 8 11;"/>
                <TextField fx:id="inputPasswordVisible"
                           promptText="••••••••"
                           visible="false" managed="false"
                           style="-fx-background-color: #F9F9F9;
                                  -fx-border-color: #E6E6E6;
                                  -fx-border-radius: 8; -fx-background-radius: 8;
                                  -fx-font-size: 13px; -fx-padding: 8 36 8 11;"/>
                <Button fx:id="btnTogglePassword"
                        text="👁"
                        onAction="#togglePassword"
                        style="-fx-background-color: transparent; -fx-cursor: hand;
                               -fx-font-size: 14px; -fx-padding: 0;"
                        StackPane.alignment="CENTER_RIGHT">
                    <StackPane.margin><Insets right="10"/></StackPane.margin>
                </Button>
            </StackPane>
            <VBox.margin><Insets bottom="2"/></VBox.margin>
        </VBox>

        <!-- Lupa Password -->
        <HBox alignment="CENTER_RIGHT">
            <Hyperlink text="Lupa password?"
                       textFill="#C0392B"
                       style="-fx-font-size: 11px; -fx-border-color: transparent;"
                       onAction="#handleForgotPassword"/>
            <VBox.margin><Insets bottom="10"/></VBox.margin>
        </HBox>

        <!-- Tombol Masuk -->
        <Button fx:id="btnMasuk"
                text="Masuk"
                maxWidth="Infinity"
                onAction="#handleLoginSubmit"
                style="-fx-background-color: #C0392B; -fx-text-fill: white;
                       -fx-font-weight: bold; -fx-font-size: 14px;
                       -fx-background-radius: 9; -fx-cursor: hand; -fx-padding: 10;">
            <VBox.margin><Insets bottom="12"/></VBox.margin>
        </Button>

        <!-- Link ke Daftar -->
        <HBox alignment="CENTER" spacing="4">
            <Label text="Belum punya akun?" textFill="#888888" style="-fx-font-size: 12px;"/>
            <Hyperlink text="Daftar"
                       textFill="#C0392B"
                       style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-border-color: transparent;"
                       onAction="#goToRegister"/>
        </HBox>

    </VBox>
</HBox>
